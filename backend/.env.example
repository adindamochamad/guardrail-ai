# Salin ke .env dan sesuaikan. Jangan commit .env.

# SQLite relatif terhadap cwd saat menjalankan uvicorn dari folder backend/
DATABASE_URL=sqlite:///./guardrail.db

# Nama layanan untuk health/metadata (opsional)
APP_NAME=GuardRail AI

# API OpenAI (opsional; untuk `gunakan_llm` pada `/detect`)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Ambang 0–1: skor_keyakinan >= nilai ini -> `apakah_ai` true
AI_DETECT_THRESHOLD=0.55

# --- Buildkite (Day 4): webhook + anotasi REST ---
# Token dari UI webhook Buildkite (plain) atau rahasia untuk X-Buildkite-Signature
BUILDKITE_WEBHOOK_TOKEN=
# Hanya dev lokal bila tidak ingin set token; jangan dipakai di produksi
BUILDKITE_WEBHOOK_ALLOW_UNVERIFIED=false
# Token API untuk POST anotasi (Bearer)
BUILDKITE_API_TOKEN=
# Slug organisasi default bila ingin anotasi tanpa mengandalkan payload
BUILDKITE_ORG_SLUG=
# true = klon repo ringkas saat webhook (perlu git + jaringan di host worker)
BUILDKITE_WEBHOOK_GIT_CLONE=false
BUILDKITE_GIT_DEPTH=1

# --- Observabilitas runtime (Sentry) — opsional; substitusi praktis saat Hud.io waitlist ---
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
# 0.0 = hanya error; naikkan untuk performance trace (perhatikan kuota)
SENTRY_TRACES_SAMPLE_RATE=0.0
# true = GET /sentry-debug (hanya lokal; matikan di produksi)
SENTRY_DEBUG_ROUTE=false
